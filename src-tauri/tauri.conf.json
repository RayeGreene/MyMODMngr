{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project Mod Manager Rivals",
  "version": "0.1.0",
  "identifier": "com.rounak77382.modmanager",
  "build": {
    "beforeDevCommand": "yarn --cwd .. dev",
    "beforeBuildCommand": "yarn --cwd .. build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../build"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [],
    "resources": [],
    "externalBin": ["sidecars/modmanager_backend"],
    "windows": {}
  },
  "app": {
    "windows": [
      {
        "title": "Project Mod Manager Rivals",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": "^https?://.*"
    },
    "deepLink": {
      "schemes": ["nxm"]
    }
  }
}
