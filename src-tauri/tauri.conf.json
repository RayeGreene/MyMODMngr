{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RivalNxt",
  "version": "0.1.0",
  "identifier": "com.rivalnxt.modmanager",
  "build": {
    "beforeDevCommand": "yarn --cwd .. dev",
    "beforeBuildCommand": "yarn --cwd .. build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../build"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/frontendlogo.ico"],
    "resources": [
      "../public/icons/kofi.svg",
      "../public/icons/upi.svg",
      "../public/icons/qr.png",
      "sidecars/repak.exe",
      "sidecars/retoc_cli.exe"
    ],
    "externalBin": ["sidecars/rivalnxt_backend"],
    "windows": {}
  },
  "app": {
    "windows": [
      {
        "title": "RivalNxt",
        "width": 1366,
        "height": 800,
        "minWidth": 1200,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": "^(https?|nxm)://.*"
    },
    "deepLink": {
      "schemes": ["nxm"]
    }
  }
}
